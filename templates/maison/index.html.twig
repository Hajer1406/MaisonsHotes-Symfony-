{% extends 'base.html.twig' %}

{% block title %}Nos Maisons | {{ parent() }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.filter-panel {
    background: #ffffff;
    border: 1px solid rgba(113, 119, 235, 0.12);
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(25, 41, 65, 0.06);
}
.filter-panel .panel-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
}
.filter-panel .panel-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
}
.filter-panel .panel-description {
    color: #6c7484;
    font-size: 0.95rem;
    margin: 0;
}
.filter-panel .form-group {
    position: relative;
}
.filter-panel label {
    display: block;
    font-size: 0.86rem;
    font-weight: 600;
    color: #4a4f59;
    margin-bottom: 0.5rem;
}
.filter-panel .form-control,
.filter-panel .form-select {
    border-radius: 14px;
    border: 1px solid #dfe3ea;
    box-shadow: none;
    padding: 0.9rem 1rem;
    height: 52px;
    color: #1f2a37;
    background: #ffffff;
}
.filter-panel .form-control:focus,
.filter-panel .form-select:focus {
    border-color: #6f7dff;
    box-shadow: 0 0 0 4px rgba(111, 125, 255, 0.12);
}
.filter-panel .form-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}
.filter-panel .form-actions .btn {
    min-height: 52px;
    padding: 0 1.35rem;
}
.filter-panel .btn-add-home {
    background: #eff3ff;
    color: #3b49e2;
    border: 1px solid rgba(59, 73, 226, 0.16);
}
.filter-panel .btn-add-home:hover {
    background: #e5ebff;
}
</style>
{% endblock %}

{% block body %}
<!-- Hero Section -->
<div class="mb-5 animate-fade-in">
    <div class="text-center py-4">
        <h1 class="display-4 fw-bold mb-3">
            <span class="text-gradient">Découvrez nos Maisons d'hôtes</span>
        </h1>
        <p class="lead text-muted">Trouvez l'hébergement parfait pour vos vacances</p>
    </div>
</div>



<!-- Search Form -->
<div class="card-modern p-4 mb-4 border border-200 shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h4 class="mb-1">
                <i class="fas fa-search text-primary me-2"></i>
                Filtrer les maisons
            </h4>
        </div>
        <!--<a href="{{ path('app_maison_new') }}" class="btn btn-modern btn-primary-modern">
            <i class="fas fa-plus me-1"></i>
            Ajouter une maison
        </a>-->
    </div>

    {{ form_start(form, {'attr': {'class': 'row gx-3 gy-3 align-items-end'}}) }}
        <div class="col-lg-4 col-md-6">
            <div class="form-group">
                {{ form_label(form.city) }}
                {{ form_widget(form.city, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.city) }}
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="form-group">
                {{ form_label(form.minPrice, 'Prix minimum (TND / nuit)') }}
                {{ form_widget(form.minPrice, {'attr': {'class': 'form-control', 'inputmode': 'decimal', 'placeholder': 'Prix min'}}) }}
                {{ form_errors(form.minPrice) }}
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="form-group">
                {{ form_label(form.maxPrice, 'Prix maximum (TND / nuit)') }}
                {{ form_widget(form.maxPrice, {'attr': {'class': 'form-control', 'inputmode': 'decimal', 'placeholder': 'Prix max'}}) }}
                {{ form_errors(form.maxPrice) }}
            </div>
        </div>

        <div class="col-lg-2 col-md-6 d-grid">
            <button type="submit" class="btn btn-modern btn-primary-modern w-100">
                <i class="fas fa-search me-1"></i>
                Rechercher
            </button>
        </div>
    {{ form_end(form) }}
</div>

<!-- Actions Bar -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div class="d-flex align-items-center gap-2">
        <span class="badge-modern badge-primary">
            <i class="fas fa-home me-1"></i>
            {{ maisons|length }} propriétés
        </span>
    </div>
    <a href="{{ path('app_maison_new') }}" class="btn btn-modern btn-primary-modern">
        <i class="fas fa-plus"></i>
        Ajouter une maison
    </a>
</div>

<!-- Properties Grid -->
{% if maisons is empty %}
<div class="text-center py-5">
    <div class="card-modern p-5">
        <i class="fas fa-home text-gradient" style="font-size: 4rem;"></i>
        <h3 class="mt-4 mb-3">Aucune maison disponible</h3>
        <p class="text-muted mb-4">Commencez par ajouter votre première propriété</p>
        <a href="{{ path('app_maison_new') }}" class="btn btn-modern btn-primary-modern">
            <i class="fas fa-plus"></i>
            Ajouter une maison
        </a>
    </div>
</div>
{% else %}
<div class="row g-4">
    {% for maison in maisons %}
    <div class="col-md-6 col-lg-4 animate-slide-up" style="animation-delay: {{ loop.index0 * 0.1 }}s;">
        <div class="property-card h-100">
            <!-- Image -->
            <div class="property-image" style="background-image: url('{% if maison.image %}/uploads/images/{{ maison.image }}{% else %}https://images.unsplash.com/photo-1564013795519-2076f76d35cd?w=400{% endif %}');">
                <span class="property-badge">
                    <i class="fas fa-star me-1"></i>Disponible
                </span>
            </div>
            
            <!-- Content -->
            <div class="property-content">
                <h3 class="property-title">{{ maison.title }}</h3>
                <p class="property-location">
                    <i class="fas fa-map-marker-alt text-danger"></i>
                    {{ maison.city }}
                </p>
                
                <p class="text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    {{ maison.description|striptags|slice(0, 100) }}{% if maison.description|length > 100 %}...{% endif %}
                </p>
                
                <div class="d-flex justify-content-between align-items-center">
                    <div class="property-price">
                        {{ maison.price }} <span>TND/nuit</span>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_maison_show', {'id': maison.id}) }}" class="btn btn-modern btn-glass" style="background: var(--primary-50); color: var(--primary-600);">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="{{ path('app_maison_edit', {'id': maison.id}) }}" class="btn btn-modern btn-glass" style="background: var(--secondary-100); color: var(--secondary-600);">
                            <i class="fas fa-edit"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

<!-- Stats Section -->
<div class="row mt-5 g-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon primary me-3">
                    <i class="fas fa-home"></i>
                </div>
                <div>
                    <div class="stat-value">{{ maisons|length }}</div>
                    <div class="stat-label">Maisons</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon success me-3">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <div>
                    {% set cities = [] %}
                    {% for m in maisons %}
                        {% if m.city not in cities %}
                            {% set cities = cities|merge([m.city]) %}
                        {% endif %}
                    {% endfor %}
                    <div class="stat-value">{{ cities|length }}</div>
                    <div class="stat-label">Villes</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon info me-3">
                    <i class="fas fa-coins"></i>
                </div>
                <div>
                    {% set total = 0 %}
                    {% for m in maisons %}
                        {% set total = total + m.price %}
                    {% endfor %}
                    <div class="stat-value">{{ maisons|length > 0 ? (total / maisons|length)|round : 0 }}</div>
                    <div class="stat-label">Prix moyen</div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
