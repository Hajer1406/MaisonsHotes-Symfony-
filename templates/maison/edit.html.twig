{% extends 'base.html.twig' %}
{% block title %}Modifier — {{ maison.title }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

.page-wrapper {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: #f8f7f4;
  min-height: calc(100vh - 200px);
  padding: 2.5rem 2rem 4rem;
}

.page-header { display: flex; align-items: center; gap: 1.1rem; margin-bottom: 2rem; flex-wrap: wrap; }
.page-icon {
  width: 54px; height: 54px; border-radius: 15px;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(99,102,241,.35); flex-shrink: 0;
}
.page-icon svg { width: 28px; height: 28px; fill: #fff; }
.page-title { font-size: 1.75rem; font-weight: 700; color: #1a1a2e; letter-spacing: -.03em; }
.page-subtitle { font-size: .85rem; color: #999; margin-top: 3px; }
.maison-badge {
  display: inline-flex; align-items: center; gap: .35rem;
  background: #f5f3ff; color: #7c3aed; border: 1px solid #e9d5ff;
  border-radius: 8px; padding: .3rem .8rem; font-size: .8rem; font-weight: 600;
}

.layout { display: grid; grid-template-columns: 1fr 300px; gap: 1.5rem; align-items: start; }
@media (max-width: 900px) { .layout { grid-template-columns: 1fr; } }

.form-card { background: #fff; border: 1px solid #ebebeb; border-radius: 20px; padding: 2rem 2.25rem; }

/* Current image sidebar card */
.image-card { background: #fff; border: 1px solid #ebebeb; border-radius: 20px; overflow: hidden; position: sticky; top: 1.5rem; }
.image-card-header { padding: 1rem 1.25rem; border-bottom: 1px solid #f0f0f0; }
.image-card-title { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: #bbb; }
.current-image { width: 100%; height: 200px; object-fit: cover; display: block; }
.current-image-placeholder {
  width: 100%; height: 200px;
  background: linear-gradient(135deg, #f5f3ff, #ede9fe);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #a78bfa; font-size: 2.5rem;
}
.image-card-body { padding: 1rem 1.25rem; }
.image-meta { font-size: .8rem; color: #888; line-height: 1.6; }
.image-meta span { display: block; }
.image-meta strong { color: #444; }

/* Price display */
.price-display {
  display: inline-flex; align-items: center; gap: .35rem;
  background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0;
  border-radius: 8px; padding: .3rem .8rem; font-size: .85rem; font-weight: 700;
  margin-top: .5rem;
}

.actions-row { display: flex; align-items: center; gap: .75rem; margin-top: 1rem; flex-wrap: wrap; }
.btn-back {
  display: inline-flex; align-items: center; gap: .4rem;
  padding: .55rem 1.1rem; background: #fff; border: 1.5px solid #e5e7eb;
  border-radius: 10px; font-size: .85rem; font-weight: 500; color: #555;
  text-decoration: none; transition: all .15s;
}
.btn-back:hover { background: #f8f7f4; color: #1a1a2e; text-decoration: none; }
.btn-back svg { width: 15px; height: 15px; }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">

  <div class="page-header">
    <div class="page-icon">
      <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
    </div>
    <div>
      <div class="page-title">
        Modifier la maison
        <span class="maison-badge" style="vertical-align:middle;margin-left:.6rem;font-size:.72rem;">#{{ maison.id }}</span>
      </div>
      <div class="page-subtitle">{{ maison.title }} — {{ maison.city }}</div>
    </div>
  </div>

  <div class="layout">

    {# ── Main form ── #}
    <div class="form-card">
      {{ include('maison/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>

    {# ── Sidebar ── #}
    <div>
      <div class="image-card">
        <div class="image-card-header">
          <div class="image-card-title">Photo actuelle</div>
        </div>
        {% if maison.image %}
          <img class="current-image" src="/uploads/images/{{ maison.image }}" alt="{{ maison.title }}">
        {% else %}
          <div class="current-image-placeholder">🏠</div>
        {% endif %}
        <div class="image-card-body">
          <div class="image-meta">
            <span><strong>Titre :</strong> {{ maison.title }}</span>
            <span><strong>Ville :</strong> {{ maison.city }}</span>
            <span><strong>Image :</strong> {{ maison.image ? maison.image : 'Aucune' }}</span>
          </div>
          <div class="price-display">
            💰 {{ maison.price }} TND / nuit
          </div>
        </div>
      </div>

      <div class="actions-row">
        <a href="{{ path('app_maison_index') }}" class="btn-back" style="flex:1; justify-content:center;">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Retour
        </a>
        {{ include('maison/_delete_form.html.twig') }}
      </div>
    </div>

  </div>
</div>
{% endblock %}
