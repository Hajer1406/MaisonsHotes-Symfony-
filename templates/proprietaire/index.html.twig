{% extends 'base.html.twig' %}

{% block title %}Propriétaires — Maisons d'hôtes{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus Jakarta+Sans:wght@400;500;600;700&display=swap');

  .page-wrapper {
    font-family: 'Plus Jakarta Sans', sans-serif;
    min-height: calc(100vh - 200px);
    background: #f8f7f4;
    padding: 2.5rem 2rem 4rem;
  }

  .page-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;
  }
  .page-header-left { display: flex; align-items: center; gap: 1rem; }
  .page-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 14px rgba(79,172,254,.35);
  }
  .page-icon svg { width: 26px; height: 26px; fill: #fff; }
  .page-title { font-size: 1.9rem; font-weight: 700; color: #1a1a2e; letter-spacing: -.03em; }
  .page-subtitle { font-size: .85rem; color: #888; margin-top: 2px; }

  .stats-row {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem; margin-bottom: 2rem;
  }
  .stat-card { background: #fff; border: 1px solid #ebebeb; border-radius: 14px; padding: 1.1rem 1.3rem; }
  .stat-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; color: #aaa; margin-bottom: .35rem; }
  .stat-value { font-size: 2rem; font-weight: 700; color: #1a1a2e; line-height: 1; }
  .stat-value.accent { color: #4facfe; }

  .toolbar { display: flex; align-items: center; gap: .75rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
  .search-box { position: relative; flex: 1; min-width: 200px; max-width: 340px; }
  .search-box svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #bbb; }
  .search-box input {
    width: 100%; padding: .55rem .9rem .55rem 2.2rem;
    border: 1.5px solid #e8e8e8; border-radius: 10px;
    font-size: .875rem; font-family: inherit; background: #fff; color: #1a1a2e;
    outline: none; transition: border-color .2s;
  }
  .search-box input:focus { border-color: #4facfe; }
  .search-box input::placeholder { color: #bbb; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .58rem 1.25rem;
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    color: #fff; border: none; border-radius: 10px; font-size: .875rem; font-weight: 600;
    font-family: inherit; cursor: pointer; text-decoration: none; transition: opacity .2s, transform .15s;
    box-shadow: 0 3px 10px rgba(79,172,254,.3);
  }
  .btn-primary:hover { opacity: .9; transform: translateY(-1px); color: #fff; text-decoration: none; }
  .btn-primary svg { width: 16px; height: 16px; }

  .table-card { background: #fff; border: 1px solid #ebebeb; border-radius: 16px; overflow: hidden; }
  .data-table { width: 100%; border-collapse: collapse; }
  .data-table thead th {
    background: #fafafa; padding: .85rem 1.25rem; text-align: left;
    font-size: .72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .08em; color: #999; border-bottom: 1px solid #f0f0f0;
  }
  .data-table tbody tr { border-bottom: 1px solid #f5f5f5; transition: background .12s; }
  .data-table tbody tr:last-child { border-bottom: none; }
  .data-table tbody tr:hover { background: #fafafa; }
  .data-table td { padding: .95rem 1.25rem; font-size: .9rem; color: #333; vertical-align: middle; }

  .owner-cell { display: flex; align-items: center; gap: .75rem; }
  .avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #e0f7ff, #b3ecff);
    display: flex; align-items: center; justify-content: center;
    font-size: .8rem; font-weight: 700; color: #0369a1; flex-shrink: 0;
  }
  .owner-name { font-weight: 600; color: #1a1a2e; }

  .phone-cell {
    display: inline-flex; align-items: center; gap: .4rem;
    color: #555; font-size: .875rem;
  }
  .phone-cell svg { width: 14px; height: 14px; color: #4facfe; }

  .actions-cell { display: flex; gap: .5rem; }
  .btn-action {
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .38rem .8rem; border-radius: 8px; font-size: .8rem; font-weight: 600;
    text-decoration: none; border: 1.5px solid transparent; transition: all .15s;
    font-family: inherit; cursor: pointer;
  }
  .btn-action svg { width: 13px; height: 13px; }
  .btn-show { background: #f0f9ff; color: #0284c7; border-color: #bae6fd; }
  .btn-show:hover { background: #e0f2fe; color: #0369a1; text-decoration: none; }
  .btn-edit { background: #f0fdf4; color: #16a34a; border-color: #bbf7d0; }
  .btn-edit:hover { background: #dcfce7; color: #15803d; text-decoration: none; }

  .empty-state { text-align: center; padding: 4rem 2rem; color: #bbb; }
  .empty-state svg { width: 56px; height: 56px; margin-bottom: 1rem; opacity: .4; }
  .empty-state p { font-size: 1rem; font-weight: 500; }
  .row-index { font-size: .8rem; color: #ccc; font-weight: 600; }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">

  <div class="page-header">
    <div class="page-header-left">
      <div class="page-icon">
        <svg viewBox="0 0 24 24"><path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/></svg>
      </div>
      <div>
        <div class="page-title">Propriétaires</div>
        <div class="page-subtitle">Gestion des propriétaires</div>
      </div>
    </div>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-label">Total propriétaires</div>
      <div class="stat-value accent">{{ proprietaires|length }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Avec téléphone</div>
      <div class="stat-value">{{ proprietaires|filter(p => p.phone is not empty)|length }}</div>
    </div>
  </div>

  <div class="toolbar">
    <div class="search-box">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" id="proSearch" placeholder="Nom, prénom, téléphone…" oninput="filterTable('proSearch','proTable')">
    </div>
    <a href="{{ path('app_proprietaire_new') }}" class="btn-primary">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Nouveau propriétaire
    </a>
  </div>

  <div class="table-card">
    <table class="data-table" id="proTable">
      <thead>
        <tr>
          <th style="width:40px">#</th>
          <th>Nom</th>
          <th>Prénom</th>
          <th>Téléphone</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for proprietaire in proprietaires %}
        <tr>
          <td class="row-index">{{ loop.index }}</td>
          <td>
            <div class="owner-cell">
              <div class="avatar">{{ proprietaire.name|first|upper }}{{ proprietaire.surname|first|upper }}</div>
              <span class="owner-name">{{ proprietaire.name }}</span>
            </div>
          </td>
          <td>{{ proprietaire.surname }}</td>
          <td>
            {% if proprietaire.phone %}
              <span class="phone-cell">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {{ proprietaire.phone }}
              </span>
            {% else %}
              <span style="color:#ccc;font-style:italic;font-size:.875rem">—</span>
            {% endif %}
          </td>
          <td>
            <div class="actions-cell">
              <a href="{{ path('app_proprietaire_show', {'id': proprietaire.id}) }}" class="btn-action btn-show">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                Voir
              </a>
              <a href="{{ path('app_proprietaire_edit', {'id': proprietaire.id}) }}" class="btn-action btn-edit">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Modifier
              </a>
            </div>
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="5">
            <div class="empty-state">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              <p>Aucun propriétaire enregistré</p>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

</div>

<script>
function filterTable(inputId, tableId) {
  const q = document.getElementById(inputId).value.toLowerCase();
  document.querySelectorAll('#' + tableId + ' tbody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
</script>
{% endblock %}
