{% extends 'base.html.twig' %}
{% block title %}{{ client.name }} {{ client.surname }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');
.page-wrapper { font-family: 'Plus Jakarta Sans', sans-serif; background: #f8f7f4; min-height: calc(100vh - 200px); padding: 2.5rem 2rem 4rem; }
.page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
.page-header-left { display: flex; align-items: center; gap: 1rem; }
.avatar-lg { width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: 700; color: #fff; flex-shrink: 0; }
.page-title { font-size: 1.7rem; font-weight: 700; color: #1a1a2e; letter-spacing: -.03em; }
.page-subtitle { font-size: .85rem; color: #888; margin-top: 2px; }
.client-id { font-size: .78rem; color: #bbb; font-weight: 500; margin-top: 3px; }

.detail-card { background: #fff; border: 1px solid #ebebeb; border-radius: 18px; overflow: hidden; max-width: 540px; }
.detail-header { padding: 1.25rem 1.75rem; border-bottom: 1px solid #f0f0f0; }
.detail-header-title { font-size: .85rem; font-weight: 700; color: #1a1a2e; text-transform: uppercase; letter-spacing: .06em; }
.detail-row { display: flex; align-items: center; padding: 1rem 1.75rem; border-bottom: 1px solid #f8f8f8; }
.detail-row:last-child { border-bottom: none; }
.detail-icon { width: 34px; height: 34px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-right: 1rem; }
.detail-icon svg { width: 17px; height: 17px; }
.icon-purple { background: #f5f3ff; color: #7c3aed; }
.icon-indigo { background: #eef2ff; color: #4338ca; }
.icon-teal { background: #f0fdfa; color: #0f766e; }
.detail-label { font-size: .75rem; color: #aaa; text-transform: uppercase; letter-spacing: .07em; margin-bottom: .15rem; font-weight: 600; }
.detail-value { font-size: .95rem; font-weight: 600; color: #1a1a2e; }
.email-link { color: #667eea; text-decoration: none; font-weight: 500; font-size: .9rem; }
.email-link:hover { text-decoration: underline; }

.actions-row { display: flex; align-items: center; gap: .75rem; margin-top: 1.5rem; flex-wrap: wrap; }
.btn-back { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1.1rem; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; font-size: .85rem; font-weight: 500; color: #555; text-decoration: none; transition: all .15s; }
.btn-back:hover { background: #f8f7f4; color: #1a1a2e; text-decoration: none; }
.btn-back svg { width: 15px; height: 15px; }
.btn-edit { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1.1rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border: none; border-radius: 10px; font-size: .85rem; font-weight: 600; text-decoration: none; transition: opacity .2s; box-shadow: 0 3px 10px rgba(102,126,234,.25); }
.btn-edit:hover { opacity: .9; color: #fff; text-decoration: none; }
.btn-edit svg { width: 15px; height: 15px; }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">

  <div class="page-header">
    <div class="page-header-left">
      <div class="avatar-lg">{{ client.name|first|upper }}{{ client.surname|first|upper }}</div>
      <div>
        <div class="page-title">{{ client.name }} {{ client.surname }}</div>
        <div class="page-subtitle">Fiche client</div>
        <div class="client-id">ID #{{ client.id }}</div>
      </div>
    </div>
  </div>

  <div class="detail-card">
    <div class="detail-header">
      <div class="detail-header-title">Informations personnelles</div>
    </div>

    <div class="detail-row">
      <div class="detail-icon icon-purple">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      </div>
      <div>
        <div class="detail-label">Nom</div>
        <div class="detail-value">{{ client.name }}</div>
      </div>
    </div>

    <div class="detail-row">
      <div class="detail-icon icon-indigo">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      </div>
      <div>
        <div class="detail-label">Prénom</div>
        <div class="detail-value">{{ client.surname }}</div>
      </div>
    </div>

    <div class="detail-row">
      <div class="detail-icon icon-teal">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <div>
        <div class="detail-label">Email</div>
        {% if client.email %}
          <a href="mailto:{{ client.email }}" class="email-link">{{ client.email }}</a>
        {% else %}
          <div class="detail-value" style="color:#ccc;font-style:italic">Non renseigné</div>
        {% endif %}
      </div>
    </div>

    <div class="detail-row">
      <div class="detail-icon icon-teal">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 16.92v3a2 2 0 01-2.18 2A19.78 19.78 0 013 5.18 2 2 0 015 3h3a2 2 0 012 1.72 12.28 12.28 0 00.7 2.81 2 2 0 01-.45 2.11L9.17 11.17a16 16 0 006.64 6.64l1.53-1.53a2 2 0 012.11-.45 12.28 12.28 0 002.81.7A2 2 0 0122 16.92z"/></svg>
      </div>
      <div>
        <div class="detail-label">Téléphone</div>
        <div class="detail-value">{{ client.phone ?: '—' }}</div>
      </div>
    </div>
  </div>

  <div class="actions-row">
    <a href="{{ path('app_client_index') }}" class="btn-back">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Retour
    </a>
    <a href="{{ path('app_client_edit', {'id': client.id}) }}" class="btn-edit">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Modifier
    </a>
    {{ include('client/_delete_form.html.twig') }}
  </div>

</div>
{% endblock %}
