{{ form_start(form, {'attr': {'class': 'pro-form', 'novalidate': 'novalidate'}}) }}

<style>
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');
.pro-form { font-family: 'Plus Jakarta Sans', sans-serif; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.form-group { display: flex; flex-direction: column; gap: .45rem; }
.form-group.full { grid-column: 1 / -1; }
.form-group label { font-size: .78rem; font-weight: 600; text-transform: uppercase; letter-spacing: .07em; color: #666; }
.pro-form input[type="text"],
.pro-form input[type="email"],
.pro-form input[type="tel"] {
  padding: .65rem 1rem; border: 1.5px solid #e5e7eb; border-radius: 10px;
  font-size: .9rem; font-family: 'Plus Jakarta Sans', sans-serif; color: #1a1a2e;
  background: #fff; outline: none; transition: border-color .2s, box-shadow .2s; width: 100%;
}
.pro-form input:focus { border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,.1); }
.pro-form input::placeholder { color: #bbb; }
.pro-form .form-error { font-size: .78rem; color: #dc2626; margin-top: .25rem; }
.form-actions { display: flex; align-items: center; gap: .75rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #f0f0f0; }
.btn-save {
  display: inline-flex; align-items: center; gap: .5rem; padding: .65rem 1.5rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border: none;
  border-radius: 10px; font-size: .9rem; font-weight: 600; font-family: inherit; cursor: pointer;
  transition: opacity .2s, transform .15s; box-shadow: 0 3px 10px rgba(102,126,234,.3);
}
.btn-save:hover { opacity: .9; transform: translateY(-1px); }
.btn-save svg { width: 16px; height: 16px; }
</style>

<div class="form-grid">
  <div class="form-group">
    {{ form_label(form.name, 'Nom') }}
    {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Ben Ali'}}) }}
    {{ form_errors(form.name) }}
  </div>

  <div class="form-group">
    {{ form_label(form.surname, 'Prénom') }}
    {{ form_widget(form.surname, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Salah'}}) }}
    {{ form_errors(form.surname) }}
  </div>

  <div class="form-group full">
    {{ form_label(form.email, 'Adresse email') }}
    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'exemple@email.com'}}) }}
    {{ form_errors(form.email) }}
  </div>

  <div class="form-group full">
    {{ form_label(form.phone, 'Téléphone') }}
    {{ form_widget(form.phone, {'attr': {'class': 'form-control', 'placeholder': '+216 00 000 000'}}) }}
    {{ form_errors(form.phone) }}
  </div>
</div>

<div class="form-actions">
  <button type="submit" class="btn-save">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    {{ button_label|default('Enregistrer') }}
  </button>
</div>

{{ form_end(form) }}
