<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Maisons d'hôtes - Votre destination de vacances parfaite">
    <title>{% block title %}Maisons d'hôtes{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><defs><linearGradient id='grad' x1='0%25' y1='0%25' x2='100%25' y2='100%25'><stop offset='0%25' style='stop-color:%23667eea;stop-opacity:1' /><stop offset='100%25' style='stop-color:%23764ba2;stop-opacity:1' /></linearGradient></defs><circle cx='50' cy='50' r='45' fill='url(%23grad)'/><path d='M50 20 L25 40 L30 40 L30 70 L45 70 L45 55 L55 55 L55 70 L70 70 L70 40 L75 40 Z' fill='white'/></svg>">
    
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/css/chatbot.css">
    {% endblock %}

    {% block javascripts %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

{# ============================================================
   Chatbot : masqué sur TOUTES les pages d'authentification.
   On utilise app.request.pathInfo (chemin URL réel) pour être
   100% fiable, indépendamment des noms de routes Symfony.
   ============================================================ #}
{% set current_path = app.request.pathInfo %}
{% set is_auth_page = (
    current_path == '/login'                     or
    current_path starts with '/register'         or
    current_path starts with '/logout'           or
    current_path starts with '/forgot-password'  or
    current_path starts with '/reset-password'   or
    current_path starts with '/verify'           or
    current_path starts with '/confirm'
) %}

{% if not is_auth_page %}
    {{ include('components/_chatbot.html.twig') }}
    <script>
    const chatHistory = [];
    let chatOpen = false;

    function toggleChat() {
        chatOpen = !chatOpen;
        const panel = document.getElementById('chatbot-panel');
        const badge = document.getElementById('chatbot-badge');
        if (chatOpen) {
            panel.classList.add('chatbot-open');
            if (badge) badge.style.display = 'none';
            document.getElementById('chatbot-input').focus();
        } else {
            panel.classList.remove('chatbot-open');
        }
    }

    function sendSuggestion(text) {
        document.getElementById('chatbot-input').value = text;
        document.querySelectorAll('.chatbot-suggestions').forEach(el => el.style.display = 'none');
        sendChat();
    }

    async function sendChat() {
        const input = document.getElementById('chatbot-input');
        const text = input.value.trim();
        if (!text) return;

        input.value = '';
        const btn = document.getElementById('chatbot-send-btn');
        btn.disabled = true;

        const msgs = document.getElementById('chatbot-messages');

        // Message utilisateur
        const userDiv = document.createElement('div');
        userDiv.className = 'user-msg';
        userDiv.textContent = text;
        msgs.appendChild(userDiv);

        // Indicateur de frappe
        const typingDiv = document.createElement('div');
        typingDiv.className = 'typing-msg';
        typingDiv.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
        msgs.appendChild(typingDiv);
        msgs.scrollTop = msgs.scrollHeight;

        chatHistory.push({ role: 'user', content: text });

        try {
            const res = await fetch('/api/chatbot', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: chatHistory })
            });
            const data = await res.json();
            typingDiv.remove();

            const botDiv = document.createElement('div');
            botDiv.className = 'bot-msg';
            botDiv.innerHTML = (data.reply || 'Désolée, une erreur est survenue.').replace(/\n/g, '<br>');
            msgs.appendChild(botDiv);

            chatHistory.push({ role: 'assistant', content: data.reply });
        } catch (e) {
            typingDiv.remove();
            const errDiv = document.createElement('div');
            errDiv.className = 'bot-msg';
            errDiv.textContent = 'Connexion impossible. Réessayez dans un moment. 🙏';
            msgs.appendChild(errDiv);
        }

        msgs.scrollTop = msgs.scrollHeight;
        btn.disabled = false;
        input.focus();
    }
    </script>
{% endif %}

<body>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-main sticky-top">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_maison_index') }}">
                <svg class="brand-logo" width="40" height="40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#f0f0f0;stop-opacity:1" />
                        </linearGradient>
                    </defs>
                    <circle cx="50" cy="50" r="45" fill="url(#logoGrad)" opacity="0.95"/>
                    <path d="M50 25 L28 43 L32 43 L32 68 L44 68 L44 56 L56 56 L56 68 L68 68 L68 43 L72 43 Z" fill="url(#grad)" stroke="url(#grad)" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M50 20 L25 40 L30 40 L30 70 L45 70 L45 55 L55 55 L55 70 L70 70 L70 40 L75 40 Z" fill="white"/>
                </svg>
                <span>Maisons d'hôtes</span>
            </a>
            
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link {% if 'maison' in app.request.get('_route') %}active{% endif %}" href="{{ path('app_maison_index') }}">
                            <i class="fas fa-home"></i>
                            <span>Maisons</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if 'client' in app.request.get('_route') %}active{% endif %}" href="{{ path('app_client_index') }}">
                            <i class="fas fa-users"></i>
                            <span>Clients</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if 'reservation' in app.request.get('_route') %}active{% endif %}" href="{{ path('app_reservation_index') }}">
                            <i class="fas fa-calendar-check"></i>
                            <span>Réservations</span>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if 'proprietaire' in app.request.get('_route') %}active{% endif %}" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-tie"></i>
                            <span>Propriétaires</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_index') }}"><i class="fas fa-list me-2"></i>Liste</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_new') }}"><i class="fas fa-plus me-2"></i>Ajouter</a></li>
                        </ul>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin') }}">
                            <i class="fas fa-chart-line"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    {% endif %}
                </ul>

                <!-- User Menu -->
                <div class="d-flex align-items-center">
                    {% if app.user %}
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i>
                                <span>{{ app.user.fullName }}</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="{{ path('app_user_account') }}"><i class="fas fa-user me-2"></i>Mon compte</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i>Déconnexion</a></li>
                            </ul>
                        </div>
                    {% else %}
                        <a class="nav-link text-white" href="{{ path('login') }}">
                            <i class="fas fa-sign-in-alt"></i>
                            <span>Connexion</span>
                        </a>
                        <a class="btn btn-glass ms-2" href="{{ path('app_register') }}">
                            <i class="fas fa-user-plus"></i>
                            <span>Inscription</span>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    <div class="container mt-4">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-modern alert-{{ label }} alert-dismissible fade show animate-fade-in" role="alert">
                    <i class="fas fa-{% if label == 'success' %}check-circle{% elseif label == 'danger' %}exclamation-circle{% elseif label == 'warning' %}exclamation-triangle{% else %}info-circle{% endif %}"></i>
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- Main Content -->
    <main class="container py-4">
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="footer-modern">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4 mb-md-0">
                    <div class="footer-brand">
                        <svg width="32" height="32" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle; margin-right: 8px;">
                            <defs>
                                <linearGradient id="footerLogoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
                                    <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
                                </linearGradient>
                            </defs>
                            <circle cx="50" cy="50" r="45" fill="url(#footerLogoGrad)"/>
                            <path d="M50 20 L25 40 L30 40 L30 70 L45 70 L45 55 L55 55 L55 70 L70 70 L70 40 L75 40 Z" fill="white"/>
                        </svg>
                        Maisons d'hôtes
                    </div>
                    <p class="mb-0">Découvrez nos propriétés d'exception pour des vacances inoubliables.</p>
                </div>
                <div class="col-md-4 mb-4 mb-md-0">
                    <h6 class="text-white mb-3">Liens Rapides</h6>
                    <div class="footer-links d-flex flex-column gap-2">
                        <a href="{{ path('app_maison_index') }}"><i class="fas fa-home me-2"></i>Nos Maisons</a>
                        <a href="{{ path('app_reservation_index') }}"><i class="fas fa-calendar me-2"></i>Réservations</a>
                        <a href="#"><i class="fas fa-info-circle me-2"></i>À propos</a>
                    </div>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Contact</h6>
                    <div class="footer-links">
                        <p class="mb-2"><i class="fas fa-envelope me-2"></i>contact@maisonshotes.com</p>
                        <p class="mb-2"><i class="fas fa-phone me-2"></i>+216 72 123 456</p>
                        <div class="d-flex gap-3 mt-3">
                            <a href="#" class="fs-5"><i class="fab fa-facebook"></i></a>
                            <a href="#" class="fs-5"><i class="fab fa-instagram"></i></a>
                            <a href="#" class="fs-5"><i class="fab fa-twitter"></i></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="mb-0">&copy; {{ "now"|date("Y") }} Maisons d'hôtes. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

</body>
</html>
