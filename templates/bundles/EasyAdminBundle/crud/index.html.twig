{% extends '@!EasyAdmin/crud/index.html.twig' %}

{% block page_actions %}
    <div class="page-actions" style="display: flex; gap: 12px; align-items: center;">
        {% for action in global_actions %}
            {{ include(action.templatePath, { action: action, entity: null }, with_context = false) }}
        {% endfor %}
    </div>
{% endblock %}

{% block table_head %}
    <thead>
        <tr>
            {% for field in entities|first.fields ?? [] %}
                <th class="text-{{ field.textAlign }}" style="padding: 16px 20px; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    {{ field.label ?? field.property|humanize }}
                    {% if field.isSortable %}
                        <span class="sort-icon" style="margin-left: 6px; opacity: 0.5;">
                            <i class="fas fa-sort"></i>
                        </span>
                    {% endif %}
                </th>
            {% endfor %}
            <th style="padding: 16px 20px; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; background: #f8fafc; border-bottom: 2px solid #e2e8f0; text-align: right;">
                Actions
            </th>
        </tr>
    </thead>
{% endblock %}

{% block table_body %}
    <tbody>
        {% for entity in entities %}
            <tr style="transition: all 0.2s ease;">
                {% for field in entity.fields %}
                    <td class="text-{{ field.textAlign }}" style="padding: 16px 20px; border-bottom: 1px solid #f1f5f9; color: #334155;">
                        {{ include(field.templatePath, { field: field, entity: entity }, with_context = false) }}
                    </td>
                {% endfor %}
                <td style="padding: 16px 20px; border-bottom: 1px solid #f1f5f9; text-align: right;">
                    {% for action in entity.actions %}
                        {{ include(action.templatePath, { action: action, entity: entity, is_index_action: true }, with_context = false) }}
                    {% endfor %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="{{ entities|first.fields|length + 1 }}" style="padding: 40px; text-align: center; color: #94a3b8;">
                    <i class="fas fa-inbox" style="font-size: 32px; margin-bottom: 12px; opacity: 0.5;"></i>
                    <p style="margin: 0; font-size: 14px;">Aucun résultat trouvé</p>
                </td>
            </tr>
        {% endfor %}
    </tbody>
{% endblock %}
